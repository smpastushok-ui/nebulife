# Nebulife client env — copy to .env.local and fill in values
#
# .env.local is gitignored (see repo .gitignore). Every worktree / clone
# needs its own .env.local for `npm run dev` and `npm run build` to work.
#
# Without these values Firebase init silently fails → the app falls into
# the legacy "Explorer" fallback path in App.tsx and testers never see
# the login screen. vite.config.ts has a build-time guard that FAILS the
# production build if any `VITE_FIREBASE_*` variable below is missing.

# ---- Firebase (client SDK) ----
# From Firebase Console → Project settings → Your apps → Config.
# Safe to expose: API key is a public identifier, not a secret.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ---- RevenueCat IAP (public SDK keys, not secrets) ----
# RevenueCat Dashboard -> Project settings -> API keys.
VITE_REVENUECAT_IOS_API_KEY=
VITE_REVENUECAT_ANDROID_API_KEY=
