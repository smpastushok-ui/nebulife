<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CAPACITOR_DEBUG</key>
	<string>$(CAPACITOR_DEBUG)</string>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
	<string>Nebulife</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<!-- arm64 only. armv7 is 32-bit and deprecated — Xcode validation fails for App Store. -->
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
	</array>
	<!-- Portrait-only. Landscape was never designed for (CommandBar + safe area). -->
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>
	<!-- AdMob iOS App ID. Currently TEST — replace with production from AdMob Console. -->
	<key>GADApplicationIdentifier</key>
	<string>ca-app-pub-3940256099942544~1458002511</string>
	<!-- Google Sign-In URL scheme. Must match REVERSED_CLIENT_ID from GoogleService-Info.plist. -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.702900049376-REPLACE_WITH_REVERSED_CLIENT_ID</string>
			</array>
		</dict>
	</array>
	<!-- App Tracking Transparency (iOS 14.5+). AdMob personalized ads require this. -->
	<key>NSUserTrackingUsageDescription</key>
	<string>Дозвіл на відстеження допомагає показувати релевантнішу рекламу та підтримувати безкоштовний доступ до гри.</string>
	<!-- Photos library (save AI-generated discovery photos to gallery). -->
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Зберегти AI-фото космічних об'єктів у вашу галерею.</string>
	<!-- Background mode for FCM push notifications. -->
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>
	<!-- Export compliance. Nebulife uses only standard HTTPS + iOS-provided crypto — exempt. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<!-- Firebase Messaging APNs integration. -->
	<key>FirebaseAppDelegateProxyEnabled</key>
	<true/>
</dict>
</plist>
