# Neon PostgreSQL connection string
DATABASE_URL=postgresql://user:password@ep-xxx-xxx.region.aws.neon.tech/nebulife?sslmode=require

# Kling AI API credentials (get from https://klingai.com)
KLING_ACCESS_KEY=your_access_key_here
KLING_SECRET_KEY=your_secret_key_here

# ---- AI model selection (server-side, no AAB rebuild needed) ----
# KLING_IMAGE_MODEL is no longer read by default — every photo-generation
# endpoint (api/kling/generate, api/surface/generate, api/system-photo/
# generate, api/tripo/generate + status, api/lifeform/photo/generate,
# api/planet-skin/generate, api/creatures/generate) now routes through
# Gemini (see GEMINI_IMAGE_MODEL below). kling-client.ts is kept in the repo
# only for the still-Kling-based video pipeline (api/lifeform/video/*,
# api/system-mission/*) and for polling any pre-existing in-flight Kling
# tasks. There is no IMAGE_PROVIDER kill-switch back to Kling for stills —
# see the model-swap report for why that was skipped.
# Valid: kling-v1, kling-v1-5, kling-v2, kling-v2-new, kling-v2-1, kling-v3
KLING_IMAGE_MODEL=kling-v3

# Kling video model used by api/system-mission/generate and
# api/lifeform/video/generate (video generation was NOT migrated to Gemini).
# Valid: kling-v1-5, kling-v2, kling-v2-1, kling-v2-6, kling-v3
# Default (when unset): kling-v3 (required for native audio)
KLING_VIDEO_MODEL=kling-v3

# Gemini image model — used by EVERY photo-generation endpoint in the game
# (see the KLING_IMAGE_MODEL note above), plus lesson/digest illustrations.
# Default (when unset): gemini-3.1-flash-lite-image (Nano Banana 2 Lite, GA
# since 2026-06-30, max resolution 1K/1024px, ~$0.0336/image). Drop-in same
# request/response shape as gemini-3.1-flash-image (Nano Banana 2, no Lite
# suffix) — set this to that value to go back to the pricier/2K-capable
# model if quality complaints outweigh the cost savings.
# NOTE: the "-preview" variant was retired by Google on 2026-06-25 (404s on
# every call) — do not set this to a "-preview" alias without first checking
# the Gemini deprecations page.
GEMINI_IMAGE_MODEL=gemini-3.1-flash-lite-image
