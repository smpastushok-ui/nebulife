{
  "buildCommand": "npm run build -w @nebulife/core && npm run build -w @nebulife/server && npm run build -w @nebulife/client",
  "outputDirectory": "packages/client/dist",
  "installCommand": "npm install --legacy-peer-deps",
  "framework": null,
  "headers": [
    {
      "source": "/app-ads.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "CDN-Cache-Control", "value": "no-store" },
        { "key": "Vercel-CDN-Cache-Control", "value": "no-store" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "CDN-Cache-Control", "value": "no-store" },
        { "key": "Vercel-CDN-Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/app-ads.txt", "destination": "/api/app-ads" },
    { "source": "/share/:discoveryId", "destination": "/api/share/:discoveryId" },
    { "source": "/photo/:photoKey", "destination": "/api/photo/:photoKey" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/support", "destination": "/support.html" },
    { "source": "/auth/apple/callback", "destination": "/api/auth/apple/callback" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/play", "destination": "/index.html" },
    { "source": "/play/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/cron/moderate", "schedule": "* * * * *" },
    { "path": "/api/cron/push-queue", "schedule": "* * * * *" },
    { "path": "/api/cron/daily-reminders", "schedule": "*/10 * * * *" },
    { "path": "/api/cron/inactivity-pushes", "schedule": "30 8 * * *" },
    { "path": "/api/cron/digest-images", "schedule": "* * * * *" },
    { "path": "/api/cron/digest-emails", "schedule": "*/10 * * * *" },
    { "path": "/api/cron/digest-pushes", "schedule": "*/10 * * * *" },
    { "path": "/api/cron/weekly-digest", "schedule": "0 8 * * 1" },
    { "path": "/api/cron/daily-quiz", "schedule": "0 9 * * *" },
    { "path": "/api/cron/daily-fact", "schedule": "0 10 * * *" },
    { "path": "/api/cron/daily-lesson", "schedule": "0 11 * * *" }
  ]
}
